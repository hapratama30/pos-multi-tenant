# Setup Supabase (jalankan migrations 001-010 berurutan di SQL Editor):
# 1. supabase/migrations/001_landing_content.sql
# Jalankan migrations 001 → 012 berurutan di Supabase SQL Editor.
# Jika error "auth_user_id does not exist", jalankan dulu:
#   supabase/migrations/012a_staff_columns_only.sql
# lalu ulangi 011 dan 012.
#
# Platform admin PIN (migration 009):
# INSERT INTO app_secrets (key, value) VALUES ('platform_admin_pin', 'PIN_PLATFORM_KUAT')
# ON CONFLICT (key) DO UPDATE SET value = EXCLUDED.value;
#
# Akses:
#   CMS Landing: https://localhost:5173/#agrapos-dev
#   Platform Admin: https://localhost:5173/#platform-admin
#
# Jalankan backend + frontend:
#   npm run server   (terminal 1)
#   npm run dev      (terminal 2)
